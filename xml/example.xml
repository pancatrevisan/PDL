<PDLApp>
    <startScreen>firstScreen</startScreen>
    <version></version>
    <name></name>
    <data>
        <PDLData  name="input_test" type="TEXT" displayOnly="false"></PDLData>  
    </data>
    
    <screens>
        <screen name="firstScreen">

            <element type="PDLButton">
                <actions>
                    <onclick>
                        <command type="NextScreen" nextScreenName="secondScreen"></command>
                    </onclick>
                </actions>
                
            </element>
        </screen>

        <screen name="secondScreen"> 
            <element type="DisplayData" data="input_test">

            </element>
        </screen>
    </screens>
</PDLApp>